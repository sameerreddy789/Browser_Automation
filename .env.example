# === REQUIRED ===
# Google Gemini API Key (used for the browser agent, coding solver, and AI consultant)
GOOGLE_API_KEY=your_gemini_api_key_here

# === TARGET COURSE ===
COURSE_NAME="2028_MBU_60 days Skill Development Assessment Course"

# === SAVED ACCOUNTS ===
# Multi-account automation reads these. Account 1 = sacrifice (discovery),
# Accounts 2+ replay corrected answers.
ACCOUNT_1_EMAIL=account1@example.com
ACCOUNT_1_PASS=account1_password

ACCOUNT_2_EMAIL=account2@example.com
ACCOUNT_2_PASS=account2_password

# === OPTIONAL: MODEL OVERRIDES ===
# Navigation brain (lightweight, fast — for clicking/reading/navigating)
# NAVIGATION_MODEL=gemini-3.1-flash-lite

# Coding brain (powerful reasoning — for DSA problem solving)
# CODING_MODEL=gemini-2.5-flash

# AI consultant (answers the agent's help requests in the terminal)
# CONSULTANT_MODEL=gemini-2.5-flash

# === OPTIONAL: PROXY ===
# Comma-separated list to enable proxy rotation. Leave empty for direct connection.
# Example: PROXY_LIST=http://user:pass@proxy1.com:8000,http://user:pass@proxy2.com:8000
PROXY_LIST=
