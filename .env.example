# Examly Credentials
EXAMLY_EMAIL=your_email@example.com
EXAMLY_PASSWORD=your_password

# Target Course Information
COURSE_NAME="2028_MBU..."
TARGET_DATE="Day 5"

# Google Gemini API Key
GOOGLE_API_KEY=your_gemini_api_key_here

# Proxy Configuration (comma-separated, leave empty to disable proxy rotation)
# Example: PROXY_LIST=http://user:pass@proxy1.com:8000,http://user:pass@proxy2.com:8000
PROXY_LIST=

# Redis Configuration (optional — falls back to local JSON if unavailable)
REDIS_HOST=localhost
REDIS_PORT=6379

# PocketBase Configuration (for HITL dashboard)
POCKETBASE_URL=http://127.0.0.1:8090
